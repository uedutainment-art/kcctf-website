  "faq": {
    "title": "Frequently Asked Questions",
    "subtitleEn": "자주 묻는 질문",
    "items": [
      {
        "q": "How do I register?",
        "a": "Click the Register button to be taken to the application page. Reservation is confirmed upon payment within 7 days of submission."
      },
      {
        "q": "What is the refund policy?",
        "a": "Please see the Refund Policy page. Partial refund available up to 30 days before the festival; refunds become difficult thereafter."
      },
      {
        "q": "Where do I send payment?",
        "a": "Shinhan Bank, account 100-038-582544 (holder: Chuncheon International Tango Festival Foundation)."
      },
      {
        "q": "Can I pay with a foreign credit card?",
        "a": "Currently we operate primarily with bank transfers. For foreign card payments, please contact info@kcctf.org for separate guidance."
      },
      {
        "q": "How do I get to Chuncheon?",
        "a": "About 60 minutes from Seoul by ITX-Cheongchun or KTX, or about 80 minutes by intercity bus. From Incheon Airport, around 2-3 hours via airport bus or ITX transfer."
      },
      {
        "q": "How do I book accommodation?",
        "a": "The most convenient option is the official hotel (The Venezia Suite) booked through our Full Pack + 2/3 nights packages. You may also book other accommodations independently."
      },
      {
        "q": "Are there workshops?",
        "a": "Workshop availability will be announced soon."
      },
      {
        "q": "Can I register on-site?",
        "a": "On-site registration is possible but may be limited if capacity is reached. Advance reservation is strongly recommended."
      }
    ]
  },
