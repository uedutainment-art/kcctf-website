# ── Site basics ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kcctf.org
NEXT_PUBLIC_REGISTER_URL=https://apply.kcctf.org/events/chuncheon-2026/register
NEXT_PUBLIC_CONTACT_EMAIL=info@kcctf.org

# ── Feature flags (운영팀 결정 미정 → false이면 섹션/요소 숨김) ──────────────
# 워크샵 섹션 (조앤 결정 후 true)
NEXT_PUBLIC_SHOW_LESSONS=false
# "제N회" 회차 표기 (확인 필요 — 현재 미정)
NEXT_PUBLIC_SHOW_EDITION_NUMBER=false
# 콘서트 장소 (문화예술회관) 별도 표기 (흰곰 결정 후 true)
NEXT_PUBLIC_SHOW_CONCERT_VENUE=false
# 숙박 패키지 가격 공개 (흰곰 결정 후 true)
NEXT_PUBLIC_SHOW_HOTEL_PACKAGES=false
# 얼리버드 마감일 (YYYY-MM-DD, 비어있으면 카운트다운 숨김)
NEXT_PUBLIC_EARLYBIRD_DEADLINE=2026-05-18
# 호텔 안내문 PDF 다운로드 URL (Google Drive 공유 링크 등)
NEXT_PUBLIC_HOTEL_PDF_URL=https://drive.google.com/file/d/17RO012mb5sEw8LhAMQuF0sU7xUB6qWfA/preview

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 — 비어있으면 비활성
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Vercel Analytics (자동 활성, 변경 불필요)
NEXT_PUBLIC_VERCEL_ANALYTICS=true
